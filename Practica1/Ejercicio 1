import time
import random

class Cronometro:
    
    def __init__(self):
        # Inicializa con 0 hasta que se llame a iniciar()
        self.__inicia = 0
        self.__finaliza = 0

    def get_inicia(self):
        return self.__inicia

    def get_finaliza(self):
        return self.__finaliza

    def iniciar(self):
        # Guarda el tiempo actual en milisegundos
        self.__inicia = time.time() * 1000

    def detener(self):
        # Guarda el tiempo actual en milisegundos
        self.__finaliza = time.time() * 1000

    def lapso_de_tiempo(self):
        return self.__finaliza - self.__inicia


# PROGRAMA DE PRUEBA

if __name__ == "__main__":

    # Crear lista con 1000 números aleatorios (no 100000 porque es muy lento)
    numeros = [random.randint(0, 100000) for _ in range(1000)]

    cron = Cronometro()

    cron.iniciar()  # ⬅️ INICIAMOS el cronómetro

    # Ordenación por selección
    for i in range(len(numeros) - 1):
        minimo = i
        for j in range(i + 1, len(numeros)):
            if numeros[j] < numeros[minimo]:
                minimo = j
        numeros[i], numeros[minimo] = numeros[minimo], numeros[i]

    cron.detener()  # ⬅️ DETENEMOS el cronómetro

    print("Tiempo en milisegundos:", cron.lapso_de_tiempo())